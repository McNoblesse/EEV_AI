# Environment variables for eeV-AI
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_NAME=text-embedding-ada-002

# Pinecone Configuration  
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
MEMORY_DB=your_database_connection_string_here

# Email Configuration
RESEND_API=your_resend_api_key_here

# Authentication
ENDPOINT_AUTH_KEY=your_endpoint_auth_key_here